# ── Bot Settings ──────────────────────────────────────────────────
# How much virtual money to start with (paper trading)
STARTING_CAPITAL=500

# % drop that triggers a stop-loss sell
STOP_LOSS_PCT=5

# % gain that triggers a take-profit sell
TAKE_PROFIT_PCT=10

# Fraction of cash to invest per trade (0.25 = 25%)
POSITION_SIZE=0.25

# Coins to track (Binance USDT pairs, comma-separated)
COINS=BTCUSDT,ETHUSDT,SOLUSDT,DOGEUSDT

# How often to run (cron syntax). Default: every 4 hours
# "0 */4 * * *"  = every 4 hours
# "0 * * * *"    = every hour
# "*/5 * * * *"  = every 5 minutes (testing only)
CRON_SCHEDULE=0 */4 * * *

# ── Live Trading (leave blank to stay in paper trading mode) ──────
# Get these from your Binance account → API Management
# WARNING: only enable after paper trading profitably for 2+ months
BINANCE_API_KEY=
BINANCE_SECRET=
